---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout title="360World — user gallery">
  <div class="mx-auto flex min-h-svh max-w-[1200px] flex-col gap-8 px-5 py-6 sm:px-10 sm:py-8">
    <header class="flex items-center justify-between">
      <a href="/" class="flex items-center gap-2.5">
        <svg
          class="size-6"
          viewBox="0 0 64 64"
          fill="none"
          stroke="currentColor"
          stroke-width="1.6"
          aria-hidden="true"
        >
          <circle cx="32" cy="32" r="22"></circle>
          <ellipse cx="32" cy="32" rx="22" ry="9"></ellipse>
          <ellipse cx="32" cy="32" rx="9" ry="22"></ellipse>
        </svg>
        <span class="font-display text-xl">360<span class="italic">World</span></span>
      </a>
      <a
        href="/app"
        class="font-mono text-[11px] uppercase tracking-[0.2em] text-[var(--color-ink-faint)] underline decoration-[var(--color-rule)] underline-offset-[6px] transition hover:text-[var(--color-ink)] hover:decoration-[var(--color-ink)]"
      >
        Open app →
      </a>
    </header>

    <section>
      <p class="kicker" id="gallery-kicker">Gallery</p>
      <h1
        id="gallery-title"
        class="mt-2 font-display text-4xl leading-tight tracking-tight sm:text-5xl"
      >
        <span class="italic">Loading</span>…
      </h1>
      <p
        id="gallery-subtitle"
        class="mt-3 font-mono text-[11px] uppercase tracking-[0.18em] text-[var(--color-ink-faint)]"
      >
        Fetching manifest from GitHub…
      </p>
    </section>

    <section>
      <div
        id="gallery"
        class="grid grid-cols-2 gap-3 sm:grid-cols-3 sm:gap-4 md:grid-cols-4 lg:grid-cols-5"
      >
      </div>
      <p
        id="gallery-empty"
        class="hidden border border-dashed border-[var(--color-rule)] bg-[var(--color-bg-soft)]/40 px-5 py-10 text-center font-mono text-[11px] uppercase tracking-[0.18em] text-[var(--color-ink-faint)]"
      >
        No worlds shared yet.
      </p>
      <p
        id="gallery-error"
        class="hidden border-l-2 border-[var(--color-flame)] bg-[var(--color-flame)]/10 px-4 py-3 text-sm text-[var(--color-flame)]"
      >
      </p>
    </section>
  </div>

  <script>
    import { GITHUB_REPO } from "../../lib/storage";
    import { fetchPublicManifest, rawThumbUrl, siteViewerUrl } from "../../lib/github";

    const $ = <T extends HTMLElement>(id: string): T => {
      const el = document.getElementById(id);
      if (!el) throw new Error(`Missing #${id}`);
      return el as T;
    };

    const els = {
      title: $<HTMLHeadingElement>("gallery-title"),
      subtitle: $<HTMLParagraphElement>("gallery-subtitle"),
      kicker: $<HTMLParagraphElement>("gallery-kicker"),
      gallery: $<HTMLDivElement>("gallery"),
      empty: $<HTMLParagraphElement>("gallery-empty"),
      error: $<HTMLParagraphElement>("gallery-error"),
    };

    function parseUsername(): string | null {
      const match = window.location.pathname.match(/^\/u\/([^/]+)\/?$/);
      return match?.[1] ? decodeURIComponent(match[1]) : null;
    }

    function showError(message: string): void {
      els.title.innerHTML = '<span class="italic">Unavailable</span>.';
      els.subtitle.textContent = "";
      els.error.textContent = message;
      els.error.classList.remove("hidden");
    }

    function formatDate(ms: number): string {
      return new Date(ms).toLocaleDateString(undefined, {
        year: "numeric",
        month: "short",
        day: "numeric",
      });
    }

    function render(
      username: string,
      items: Array<{ slug: string; prompt: string; createdAt: number }>,
    ): void {
      els.kicker.textContent = `@${username}`;
      els.title.innerHTML = `<span class="italic">${username}</span>'s worlds`;
      els.subtitle.textContent = `${items.length} panorama${items.length === 1 ? "" : "s"}`;
      if (items.length === 0) {
        els.empty.classList.remove("hidden");
        return;
      }
      const fragment = document.createDocumentFragment();
      for (const item of items) {
        const card = document.createElement("a");
        card.href = siteViewerUrl(username, item.slug);
        card.className =
          "group relative block overflow-hidden border border-[var(--color-rule)] bg-[var(--color-bg-soft)] transition hover:border-[var(--color-flame)]";

        const img = document.createElement("img");
        img.src = rawThumbUrl(username, item.slug);
        img.alt = item.prompt;
        img.loading = "lazy";
        img.className = "aspect-[2/1] w-full object-cover transition group-hover:scale-[1.02]";

        const overlay = document.createElement("div");
        overlay.className =
          "pointer-events-none absolute inset-0 flex flex-col justify-end bg-gradient-to-t from-black/85 via-black/0 to-transparent p-3 opacity-0 transition group-hover:opacity-100";
        const caption = document.createElement("p");
        caption.className = "line-clamp-2 font-display text-[13px] italic text-white sm:text-sm";
        caption.textContent = item.prompt;
        const date = document.createElement("p");
        date.className = "mt-1 font-mono text-[10px] uppercase tracking-[0.16em] text-white/70";
        date.textContent = formatDate(item.createdAt);
        overlay.appendChild(caption);
        overlay.appendChild(date);

        card.appendChild(img);
        card.appendChild(overlay);
        fragment.appendChild(card);
      }
      els.gallery.appendChild(fragment);
    }

    void (async () => {
      const username = parseUsername();
      if (!username) {
        showError("Invalid gallery URL.");
        return;
      }
      try {
        const manifest = await fetchPublicManifest(username);
        render(username, manifest.items);
      } catch (err) {
        const e = err as Error;
        showError(
          `Could not load @${username}'s gallery — ${e.message}. The repo "${GITHUB_REPO}" may not exist or may not be public.`,
        );
      }
    })();
  </script>
</BaseLayout>
