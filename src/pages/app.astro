---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="360World — generator">
  <div class="mx-auto flex min-h-svh max-w-[1200px] flex-col gap-8 px-5 py-6 sm:px-10 sm:py-8">
    <!-- Top bar -->
    <header class="flex items-center justify-between">
      <a href="/" class="flex items-center gap-2.5">
        <svg
          class="size-6"
          viewBox="0 0 64 64"
          fill="none"
          stroke="currentColor"
          stroke-width="1.6"
          aria-hidden="true"
        >
          <circle cx="32" cy="32" r="22"></circle>
          <ellipse cx="32" cy="32" rx="22" ry="9"></ellipse>
          <ellipse cx="32" cy="32" rx="9" ry="22"></ellipse>
        </svg>
        <span class="font-display text-xl">360<span class="italic">World</span></span>
      </a>
      <button
        id="settings-btn"
        type="button"
        class="font-mono text-[11px] uppercase tracking-[0.2em] text-[var(--color-ink-faint)] underline decoration-[var(--color-rule)] underline-offset-[6px] transition hover:text-[var(--color-ink)] hover:decoration-[var(--color-ink)]"
      >
        Settings
      </button>
    </header>

    <!-- Prompt -->
    <section>
      <form id="prompt-form" class="flex flex-col gap-3 sm:flex-row sm:items-stretch">
        <label for="prompt-input" class="sr-only">Describe the world you want to step into</label>
        <textarea
          id="prompt-input"
          name="prompt"
          rows="2"
          required
          maxlength="900"
          placeholder="An abandoned space station orbiting a ringed planet, soft sunrise light…"
          class="flex-1 resize-none border border-[var(--color-rule)] bg-[var(--color-bg-soft)] px-4 py-3.5 font-display text-lg leading-snug text-[var(--color-ink)] placeholder:text-[var(--color-ink-faint)] focus:border-[var(--color-flame)] focus:outline-none focus:ring-0 sm:text-xl"
        ></textarea>
        <button
          id="generate-btn"
          type="submit"
          class="group relative inline-flex shrink-0 items-center justify-center gap-3 bg-[var(--color-ink)] px-7 py-4 font-mono text-[11px] uppercase tracking-[0.2em] text-[var(--color-bg)] transition hover:bg-[var(--color-flame)] disabled:cursor-not-allowed disabled:opacity-60"
        >
          <span id="generate-label">Generate →</span>
          <span
            id="generate-spinner"
            class="hidden size-3.5 animate-spin rounded-full border-[1.5px] border-[var(--color-bg)]/40 border-t-[var(--color-bg)]"
          ></span>
        </button>
      </form>
      <p
        class="mt-2.5 font-mono text-[11px] uppercase tracking-[0.16em] text-[var(--color-ink-faint)]"
      >
        — Tip: describe a place, not just an object. The 360° framing is handled for you.
      </p>
    </section>

    <!-- Viewer -->
    <section
      id="viewer-section"
      class="relative aspect-[3/2] w-full overflow-hidden border border-[var(--color-rule)] bg-[var(--color-bg-deep)]"
    >
      <div id="viewer" class="absolute inset-0" style="touch-action: none;"></div>

      <div
        id="viewer-empty"
        class="absolute inset-0 flex flex-col items-center justify-center gap-4 bg-[var(--color-bg-soft)]/60 p-8 text-center"
      >
        <svg
          class="size-16 text-[var(--color-ink-faint)] sm:size-20"
          viewBox="-110 -110 220 220"
          fill="none"
          stroke="currentColor"
          stroke-width="0.8"
          aria-hidden="true"
        >
          <circle r="100"></circle>
          <ellipse rx="100" ry="40"></ellipse>
          <ellipse rx="40" ry="100"></ellipse>
          <line x1="-100" y1="0" x2="100" y2="0"></line>
          <circle r="3" fill="var(--color-flame)" stroke="none"></circle>
        </svg>
        <p class="font-display text-2xl text-[var(--color-ink)] sm:text-3xl">
          <span class="italic">Your next world</span> appears here.
        </p>
        <p
          class="max-w-md font-mono text-[11px] uppercase tracking-[0.16em] text-[var(--color-ink-faint)]"
        >
          Drag to look around · pinch to zoom · tilt your phone for gyroscope
        </p>
      </div>

      <div id="gyro-banner" class="absolute right-3 top-3 hidden">
        <button
          id="gyro-btn"
          type="button"
          class="pointer-events-auto bg-[var(--color-ink)] px-3 py-1.5 font-mono text-[10px] uppercase tracking-[0.2em] text-[var(--color-bg)] shadow-lg transition hover:bg-[var(--color-flame)]"
        >
          Enable gyroscope
        </button>
      </div>

      <div
        id="viewer-meta"
        class="pointer-events-none absolute bottom-0 left-0 right-0 hidden bg-gradient-to-t from-black/85 via-black/40 to-transparent p-4 sm:p-5"
      >
        <p
          id="viewer-prompt"
          class="font-display text-base italic text-white sm:text-lg [overflow-wrap:anywhere]"
        >
        </p>
        <div class="mt-3 flex flex-wrap items-center gap-2">
          <button
            id="download-btn"
            type="button"
            class="pointer-events-auto bg-white/10 px-3 py-1.5 font-mono text-[10px] uppercase tracking-[0.2em] text-white backdrop-blur transition hover:bg-[var(--color-flame)]"
          >
            ↓ Download
          </button>
        </div>
      </div>
    </section>

    <!-- Gallery -->
    <section>
      <div class="mb-4 flex items-end justify-between gap-3">
        <div class="flex items-baseline gap-3">
          <h2 class="font-display text-2xl tracking-tight sm:text-3xl">Library</h2>
          <span id="gallery-count" class="kicker hidden">— 0 worlds</span>
        </div>
        <button
          id="clear-gallery-btn"
          type="button"
          class="hidden font-mono text-[11px] uppercase tracking-[0.18em] text-[var(--color-ink-faint)] underline decoration-[var(--color-rule)] underline-offset-[5px] transition hover:text-[var(--color-flame)] hover:decoration-[var(--color-flame)]"
        >
          Clear all
        </button>
      </div>
      <div
        id="gallery"
        class="grid grid-cols-2 gap-3 sm:grid-cols-3 sm:gap-4 md:grid-cols-4 lg:grid-cols-5"
      >
      </div>
      <p
        id="gallery-empty"
        class="border border-dashed border-[var(--color-rule)] bg-[var(--color-bg-soft)]/40 px-5 py-10 text-center font-mono text-[11px] uppercase tracking-[0.18em] text-[var(--color-ink-faint)]"
      >
        Empty for now — every world you make lands here.
      </p>
    </section>
  </div>

  <!-- API key modal -->
  <div
    id="key-modal"
    aria-hidden="true"
    class="fixed inset-0 z-40 hidden items-center justify-center bg-black/75 p-4 backdrop-blur-sm"
  >
    <div
      class="w-full max-w-lg border border-[var(--color-rule)] bg-[var(--color-bg-soft)] p-7 shadow-[0_30px_80px_-30px_rgba(0,0,0,0.8)] sm:p-9"
    >
      <span class="kicker">Bring-your-own-key</span>
      <h2 class="mt-3 font-display text-3xl leading-tight tracking-tight sm:text-4xl">
        Connect your <span class="italic">Replicate</span> key.
      </h2>
      <p class="mt-3 text-sm leading-relaxed text-[var(--color-ink-soft)]">
        Stored in this browser only. Never logged on our side. Create an account and grab a key at
        <a
          class="text-[var(--color-flame)] underline decoration-[var(--color-flame)]/40 underline-offset-[5px] hover:decoration-[var(--color-flame)]"
          href="https://replicate.com/account/api-tokens"
          target="_blank"
          rel="noreferrer noopener">replicate.com/account/api-tokens</a
        >.
      </p>
      <div class="mt-5 border-l-2 border-[var(--color-flame)] bg-[var(--color-flame)]/5 px-4 py-3">
        <p class="kicker text-[var(--color-flame)]">Why Replicate?</p>
        <p class="mt-2 text-[13px] leading-relaxed text-[var(--color-ink-soft)]">
          Replicate is a hub that hosts image models from many different providers. Plugging in one
          Replicate key now means 360World can offer you a choice of models later — without ever
          asking you to juggle multiple accounts.
        </p>
      </div>
      <form id="key-form" class="mt-6 flex flex-col gap-3">
        <label for="key-input" class="kicker">API token</label>
        <input
          id="key-input"
          type="password"
          autocomplete="off"
          spellcheck="false"
          required
          placeholder="r8_..."
          class="border border-[var(--color-rule)] bg-[var(--color-bg)] px-4 py-3 font-mono text-sm text-[var(--color-ink)] placeholder:text-[var(--color-ink-faint)] focus:border-[var(--color-flame)] focus:outline-none"
        />
        <p
          id="key-error"
          class="hidden border-l-2 border-[var(--color-flame)] bg-[var(--color-flame)]/10 px-3 py-2 text-xs text-[var(--color-flame)]"
        >
        </p>
        <p class="font-mono text-[10px] uppercase tracking-[0.16em] text-[var(--color-ink-faint)]">
          ⚠ Stored locally — don't use this app on a shared device.
        </p>
        <div class="mt-3 flex flex-wrap items-center justify-between gap-3">
          <button
            id="forget-key-btn"
            type="button"
            class="hidden font-mono text-[11px] uppercase tracking-[0.18em] text-[var(--color-ink-faint)] underline decoration-[var(--color-rule)] underline-offset-[5px] transition hover:text-[var(--color-flame)] hover:decoration-[var(--color-flame)]"
          >
            Forget my key
          </button>
          <div class="flex gap-2">
            <button
              id="key-cancel-btn"
              type="button"
              class="hidden border border-[var(--color-rule)] bg-transparent px-5 py-2.5 font-mono text-[11px] uppercase tracking-[0.2em] text-[var(--color-ink)] transition hover:border-[var(--color-ink)]"
            >
              Cancel
            </button>
            <button
              type="submit"
              id="key-save-btn"
              class="bg-[var(--color-ink)] px-5 py-2.5 font-mono text-[11px] uppercase tracking-[0.2em] text-[var(--color-bg)] transition hover:bg-[var(--color-flame)] disabled:opacity-60"
            >
              Save & continue
            </button>
          </div>
        </div>
      </form>
    </div>
  </div>

  <!-- Toast -->
  <div
    id="toast"
    role="status"
    aria-live="polite"
    class="pointer-events-none fixed bottom-6 left-1/2 z-50 hidden -translate-x-1/2 border border-[var(--color-ink)] bg-[var(--color-ink)] px-4 py-2 font-mono text-[11px] uppercase tracking-[0.18em] text-[var(--color-bg)] shadow-2xl"
  >
  </div>

  <script>
    import { apiKeyStore, imagesStore, type StoredImage } from "../lib/storage";
    import { fetchImageBlob, generate360Image } from "../lib/replicate";
    import { downloadBlob, suggestedFilename } from "../lib/download";
    import { toEquirectangularBlob } from "../lib/equirect";

    type ViewerCtor = typeof import("@photo-sphere-viewer/core").Viewer;
    type GyroPlugin = import("@photo-sphere-viewer/gyroscope-plugin").GyroscopePlugin;

    const $ = <T extends HTMLElement>(id: string): T => {
      const el = document.getElementById(id);
      if (!el) throw new Error(`Missing #${id}`);
      return el as T;
    };

    const els = {
      promptForm: $<HTMLFormElement>("prompt-form"),
      promptInput: $<HTMLTextAreaElement>("prompt-input"),
      generateBtn: $<HTMLButtonElement>("generate-btn"),
      generateLabel: $<HTMLSpanElement>("generate-label"),
      generateSpinner: $<HTMLSpanElement>("generate-spinner"),
      viewerSection: $<HTMLElement>("viewer-section"),
      viewer: $<HTMLDivElement>("viewer"),
      viewerEmpty: $<HTMLDivElement>("viewer-empty"),
      viewerMeta: $<HTMLDivElement>("viewer-meta"),
      viewerPrompt: $<HTMLParagraphElement>("viewer-prompt"),
      downloadBtn: $<HTMLButtonElement>("download-btn"),
      gyroBanner: $<HTMLDivElement>("gyro-banner"),
      gyroBtn: $<HTMLButtonElement>("gyro-btn"),
      gallery: $<HTMLDivElement>("gallery"),
      galleryEmpty: $<HTMLParagraphElement>("gallery-empty"),
      galleryCount: $<HTMLSpanElement>("gallery-count"),
      clearGalleryBtn: $<HTMLButtonElement>("clear-gallery-btn"),
      settingsBtn: $<HTMLButtonElement>("settings-btn"),
      keyModal: $<HTMLDivElement>("key-modal"),
      keyForm: $<HTMLFormElement>("key-form"),
      keyInput: $<HTMLInputElement>("key-input"),
      keyError: $<HTMLParagraphElement>("key-error"),
      keySave: $<HTMLButtonElement>("key-save-btn"),
      keyCancel: $<HTMLButtonElement>("key-cancel-btn"),
      forgetKey: $<HTMLButtonElement>("forget-key-btn"),
      toast: $<HTMLDivElement>("toast"),
    };

    let viewerInstance: InstanceType<ViewerCtor> | null = null;
    let viewerObjectUrl: string | null = null;
    let currentImage: StoredImage | null = null;
    let toastTimer: number | null = null;
    let viewerModule: typeof import("@photo-sphere-viewer/core") | null = null;
    let gyroModule: typeof import("@photo-sphere-viewer/gyroscope-plugin") | null = null;

    async function loadViewerModules(): Promise<void> {
      if (viewerModule && gyroModule) return;
      [viewerModule, gyroModule] = await Promise.all([
        import("@photo-sphere-viewer/core"),
        import("@photo-sphere-viewer/gyroscope-plugin"),
      ]);
    }

    function showToast(message: string, kind: "info" | "error" = "info"): void {
      els.toast.textContent = message;
      els.toast.classList.remove("hidden");
      els.toast.style.background = kind === "error" ? "var(--color-flame-deep)" : "var(--color-ink)";
      els.toast.style.color = kind === "error" ? "var(--color-ink)" : "var(--color-bg)";
      els.toast.style.borderColor = kind === "error" ? "var(--color-flame-deep)" : "var(--color-ink)";
      if (toastTimer) window.clearTimeout(toastTimer);
      toastTimer = window.setTimeout(() => els.toast.classList.add("hidden"), 4500);
    }

    function setBusy(busy: boolean, label = "Generating…"): void {
      els.generateBtn.disabled = busy;
      els.promptInput.disabled = busy;
      els.generateLabel.textContent = busy ? label : "Generate →";
      els.generateSpinner.classList.toggle("hidden", !busy);
    }

    function openModal(mode: "onboarding" | "settings"): void {
      els.keyModal.classList.remove("hidden");
      els.keyModal.classList.add("flex");
      els.keyModal.setAttribute("aria-hidden", "false");
      els.keyError.classList.add("hidden");
      els.keyInput.value = "";
      const isSettings = mode === "settings";
      els.keyCancel.classList.toggle("hidden", !isSettings);
      els.forgetKey.classList.toggle("hidden", !isSettings);
      setTimeout(() => els.keyInput.focus(), 50);
    }

    function closeModal(): void {
      els.keyModal.classList.add("hidden");
      els.keyModal.classList.remove("flex");
      els.keyModal.setAttribute("aria-hidden", "true");
    }

    async function ensureKey(): Promise<string | null> {
      const key = await apiKeyStore.get();
      if (!key) {
        openModal("onboarding");
        return null;
      }
      return key;
    }

    function isMobile(): boolean {
      return window.matchMedia("(pointer: coarse)").matches;
    }

    async function showImage(image: StoredImage): Promise<void> {
      currentImage = image;
      await loadViewerModules();
      const { Viewer } = viewerModule!;
      const { GyroscopePlugin } = gyroModule!;

      if (viewerObjectUrl) {
        URL.revokeObjectURL(viewerObjectUrl);
        viewerObjectUrl = null;
      }
      const equirectBlob = await toEquirectangularBlob(image.blob, {
        type: image.contentType,
      });
      viewerObjectUrl = URL.createObjectURL(equirectBlob);

      els.viewerEmpty.classList.add("hidden");
      els.viewerMeta.classList.remove("hidden");
      els.viewerPrompt.textContent = image.prompt;
      if (isMobile()) {
        els.gyroBanner.classList.remove("hidden");
      }

      if (viewerInstance) {
        viewerInstance.destroy();
        viewerInstance = null;
      }

      viewerInstance = new Viewer({
        container: els.viewer,
        panorama: viewerObjectUrl,
        navbar: ["zoom", "move", "fullscreen"],
        defaultPitch: 0,
        defaultYaw: 0,
        plugins: [[GyroscopePlugin, { touchmove: true }]],
      });
    }

    function destroyViewer(): void {
      if (viewerInstance) {
        viewerInstance.destroy();
        viewerInstance = null;
      }
      if (viewerObjectUrl) {
        URL.revokeObjectURL(viewerObjectUrl);
        viewerObjectUrl = null;
      }
      currentImage = null;
      els.viewerEmpty.classList.remove("hidden");
      els.viewerMeta.classList.add("hidden");
      els.gyroBanner.classList.add("hidden");
    }

    async function refreshGallery(): Promise<void> {
      const items = await imagesStore.list();
      els.gallery.innerHTML = "";
      if (items.length === 0) {
        els.galleryEmpty.classList.remove("hidden");
        els.clearGalleryBtn.classList.add("hidden");
        els.galleryCount.classList.add("hidden");
        return;
      }
      els.galleryEmpty.classList.add("hidden");
      els.clearGalleryBtn.classList.remove("hidden");
      els.galleryCount.classList.remove("hidden");
      els.galleryCount.textContent = `— ${items.length} world${items.length > 1 ? "s" : ""}`;

      const fragment = document.createDocumentFragment();
      for (const item of items) {
        const card = document.createElement("article");
        card.className =
          "group relative overflow-hidden border border-[var(--color-rule)] bg-[var(--color-bg-soft)] transition hover:border-[var(--color-flame)] cursor-pointer";

        const img = document.createElement("img");
        const objectUrl = URL.createObjectURL(item.blob);
        img.src = objectUrl;
        img.alt = item.prompt;
        img.loading = "lazy";
        img.className = "aspect-[3/2] w-full object-cover transition group-hover:scale-[1.02]";
        img.addEventListener("load", () => URL.revokeObjectURL(objectUrl), { once: true });

        const overlay = document.createElement("div");
        overlay.className =
          "pointer-events-none absolute inset-0 flex flex-col justify-end bg-gradient-to-t from-black/85 via-black/0 to-transparent p-3 opacity-0 transition group-hover:opacity-100";
        const caption = document.createElement("p");
        caption.className =
          "line-clamp-2 font-display text-[13px] italic text-white sm:text-sm";
        caption.textContent = item.prompt;
        overlay.appendChild(caption);

        const actions = document.createElement("div");
        actions.className = "pointer-events-auto absolute right-2 top-2 flex gap-1.5";

        const downloadBtn = document.createElement("button");
        downloadBtn.type = "button";
        downloadBtn.title = "Download";
        downloadBtn.className =
          "bg-[var(--color-bg)]/85 px-2 py-1 font-mono text-[10px] text-[var(--color-ink)] backdrop-blur transition hover:bg-[var(--color-flame)] hover:text-[var(--color-bg)]";
        downloadBtn.textContent = "↓";
        downloadBtn.addEventListener("click", (e) => {
          e.stopPropagation();
          downloadBlob(item.blob, suggestedFilename(item.prompt));
        });

        const removeBtn = document.createElement("button");
        removeBtn.type = "button";
        removeBtn.title = "Remove";
        removeBtn.className =
          "bg-[var(--color-bg)]/85 px-2 py-1 font-mono text-[10px] text-[var(--color-ink)] backdrop-blur transition hover:bg-[var(--color-flame-deep)] hover:text-[var(--color-ink)]";
        removeBtn.textContent = "✕";
        removeBtn.addEventListener("click", async (e) => {
          e.stopPropagation();
          await imagesStore.remove(item.id);
          if (currentImage?.id === item.id) destroyViewer();
          await refreshGallery();
        });

        actions.appendChild(downloadBtn);
        actions.appendChild(removeBtn);

        card.appendChild(img);
        card.appendChild(overlay);
        card.appendChild(actions);
        card.addEventListener("click", () => {
          void showImage(item);
          els.viewerSection.scrollIntoView({ behavior: "smooth", block: "start" });
        });
        fragment.appendChild(card);
      }
      els.gallery.appendChild(fragment);
    }

    async function handleGenerate(event: SubmitEvent): Promise<void> {
      event.preventDefault();
      const prompt = els.promptInput.value.trim();
      if (!prompt) return;
      const key = await ensureKey();
      if (!key) return;

      setBusy(true, "Starting…");
      try {
        const generated = await generate360Image({
          apiKey: key,
          prompt,
          onProgress: (e) => {
            const seconds = Math.round(e.elapsedMs / 1000);
            const verb = e.status === "starting" ? "Warming up" : "Painting";
            setBusy(true, `${verb} · ${seconds}s`);
          },
        });
        setBusy(true, "Downloading…");
        const blob = await fetchImageBlob(generated.url);
        const stored = await imagesStore.add({
          prompt: generated.prompt,
          finalPrompt: generated.finalPrompt,
          blob,
          contentType: blob.type || "image/webp",
        });
        await refreshGallery();
        await showImage(stored);
        els.promptInput.value = "";
        showToast("World ready — drag to explore.");
      } catch (error) {
        const err = error as Error;
        if (err.name === "InvalidApiKeyError") {
          openModal("settings");
          showToast(err.message, "error");
        } else {
          showToast(err.message ?? "Generation failed.", "error");
        }
      } finally {
        setBusy(false);
      }
    }

    async function handleSaveKey(event: SubmitEvent): Promise<void> {
      event.preventDefault();
      const value = els.keyInput.value.trim();
      if (!value) return;
      els.keySave.disabled = true;
      try {
        await apiKeyStore.set(value);
        els.keyError.classList.add("hidden");
        closeModal();
        showToast("Key saved locally.");
      } catch (error) {
        const err = error as Error;
        els.keyError.textContent = err.message;
        els.keyError.classList.remove("hidden");
      } finally {
        els.keySave.disabled = false;
      }
    }

    async function enableGyroscope(): Promise<void> {
      if (!viewerInstance || !gyroModule) return;
      const plugin = viewerInstance.getPlugin(gyroModule.GyroscopePlugin) as GyroPlugin | null;
      if (!plugin) {
        showToast("Gyroscope plugin not available.", "error");
        return;
      }
      try {
        await plugin.start();
        els.gyroBtn.textContent = "Gyroscope on";
      } catch (error) {
        const err = error as Error;
        showToast(err.message ?? "Could not enable gyroscope.", "error");
      }
    }

    els.promptForm.addEventListener("submit", handleGenerate);
    els.keyForm.addEventListener("submit", handleSaveKey);
    els.settingsBtn.addEventListener("click", () => openModal("settings"));
    els.keyCancel.addEventListener("click", closeModal);
    els.forgetKey.addEventListener("click", async () => {
      await apiKeyStore.clear();
      closeModal();
      showToast("Key removed from this browser.");
    });
    els.downloadBtn.addEventListener("click", () => {
      if (!currentImage) return;
      downloadBlob(currentImage.blob, suggestedFilename(currentImage.prompt));
    });
    els.clearGalleryBtn.addEventListener("click", async () => {
      const ok = window.confirm("Delete every image stored in this browser?");
      if (!ok) return;
      await imagesStore.clear();
      destroyViewer();
      await refreshGallery();
    });
    els.gyroBtn.addEventListener("click", () => void enableGyroscope());
    els.keyModal.addEventListener("click", (e) => {
      if (e.target === els.keyModal && !els.keyCancel.classList.contains("hidden")) {
        closeModal();
      }
    });

    void (async () => {
      await refreshGallery();
      const items = await imagesStore.list();
      if (items.length > 0) {
        await showImage(items[0]!);
      }
      const key = await apiKeyStore.get();
      if (!key) openModal("onboarding");
    })();
  </script>
</BaseLayout>
