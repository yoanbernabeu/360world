---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="360World — generator">
  <div class="mx-auto flex min-h-svh max-w-[1200px] flex-col gap-8 px-5 py-6 sm:px-10 sm:py-8">
    <!-- Top bar -->
    <header class="flex items-center justify-between">
      <a href="/" class="flex items-center gap-2.5">
        <svg
          class="size-6"
          viewBox="0 0 64 64"
          fill="none"
          stroke="currentColor"
          stroke-width="1.6"
          aria-hidden="true"
        >
          <circle cx="32" cy="32" r="22"></circle>
          <ellipse cx="32" cy="32" rx="22" ry="9"></ellipse>
          <ellipse cx="32" cy="32" rx="9" ry="22"></ellipse>
        </svg>
        <span class="font-display text-xl">360<span class="italic">World</span></span>
      </a>
      <div class="flex items-center gap-5">
        <a
          id="my-gallery-link"
          href="#"
          target="_blank"
          rel="noreferrer noopener"
          class="hidden font-mono text-[11px] uppercase tracking-[0.2em] text-[var(--color-ink-faint)] underline decoration-[var(--color-rule)] underline-offset-[6px] transition hover:text-[var(--color-flame)] hover:decoration-[var(--color-flame)]"
        >
          My gallery ↗
        </a>
        <button
          id="settings-btn"
          type="button"
          class="font-mono text-[11px] uppercase tracking-[0.2em] text-[var(--color-ink-faint)] underline decoration-[var(--color-rule)] underline-offset-[6px] transition hover:text-[var(--color-ink)] hover:decoration-[var(--color-ink)]"
        >
          Settings
        </button>
      </div>
    </header>

    <!-- Prompt -->
    <section>
      <div id="provider-switch-wrapper" class="mb-3 hidden flex-wrap items-center gap-3">
        <span class="kicker">Provider</span>
        <div
          id="provider-switch"
          role="tablist"
          aria-label="Image provider"
          class="inline-flex border border-[var(--color-rule)]"
        >
          <button
            type="button"
            role="tab"
            data-provider="openai"
            aria-selected="true"
            class="provider-tab px-3 py-1.5 font-mono text-[11px] uppercase tracking-[0.18em] transition"
          >
            OpenAI
          </button>
          <button
            type="button"
            role="tab"
            data-provider="replicate"
            aria-selected="false"
            class="provider-tab px-3 py-1.5 font-mono text-[11px] uppercase tracking-[0.18em] transition"
          >
            Replicate
          </button>
        </div>
      </div>

      <form id="prompt-form" class="flex flex-col gap-3 sm:flex-row sm:items-stretch">
        <label for="prompt-input" class="sr-only">Describe the world you want to step into</label>
        <textarea
          id="prompt-input"
          name="prompt"
          rows="2"
          required
          maxlength="900"
          placeholder="An abandoned space station orbiting a ringed planet, soft sunrise light…"
          class="flex-1 resize-none border border-[var(--color-rule)] bg-[var(--color-bg-soft)] px-4 py-3.5 font-display text-lg leading-snug text-[var(--color-ink)] placeholder:text-[var(--color-ink-faint)] focus:border-[var(--color-flame)] focus:outline-none focus:ring-0 sm:text-xl"
        ></textarea>
        <button
          id="generate-btn"
          type="submit"
          class="group relative inline-flex shrink-0 items-center justify-center gap-3 bg-[var(--color-ink)] px-7 py-4 font-mono text-[11px] uppercase tracking-[0.2em] text-[var(--color-bg)] transition hover:bg-[var(--color-flame)] disabled:cursor-not-allowed disabled:opacity-60"
        >
          <span id="generate-label">Generate →</span>
          <span
            id="generate-spinner"
            class="hidden size-3.5 animate-spin rounded-full border-[1.5px] border-[var(--color-bg)]/40 border-t-[var(--color-bg)]"
          ></span>
        </button>
      </form>

      <div
        id="openai-options"
        class="mt-3 flex flex-wrap items-center gap-4 border-l-2 border-[var(--color-rule)] bg-[var(--color-bg-soft)]/40 px-4 py-2.5"
      >
        <div class="flex items-center gap-2">
          <label for="openai-size" class="kicker">Size</label>
          <select
            id="openai-size"
            class="border border-[var(--color-rule)] bg-[var(--color-bg)] px-2 py-1 font-mono text-[11px] uppercase tracking-[0.12em] text-[var(--color-ink)] focus:border-[var(--color-flame)] focus:outline-none"
          >
          </select>
        </div>
        <div class="flex items-center gap-2">
          <label for="openai-quality" class="kicker">Quality</label>
          <select
            id="openai-quality"
            class="border border-[var(--color-rule)] bg-[var(--color-bg)] px-2 py-1 font-mono text-[11px] uppercase tracking-[0.12em] text-[var(--color-ink)] focus:border-[var(--color-flame)] focus:outline-none"
          >
          </select>
        </div>
      </div>

      <p
        class="mt-2.5 font-mono text-[11px] uppercase tracking-[0.16em] text-[var(--color-ink-faint)]"
      >
        — Tip: describe a place, not just an object. The 360° framing is handled for you.
      </p>
    </section>

    <!-- Viewer -->
    <section
      id="viewer-section"
      class="relative aspect-[3/2] w-full overflow-hidden border border-[var(--color-rule)] bg-[var(--color-bg-deep)]"
    >
      <div id="viewer" class="absolute inset-0" style="touch-action: none;"></div>

      <div
        id="viewer-empty"
        class="absolute inset-0 flex flex-col items-center justify-center gap-4 bg-[var(--color-bg-soft)]/60 p-8 text-center"
      >
        <svg
          class="size-16 text-[var(--color-ink-faint)] sm:size-20"
          viewBox="-110 -110 220 220"
          fill="none"
          stroke="currentColor"
          stroke-width="0.8"
          aria-hidden="true"
        >
          <circle r="100"></circle>
          <ellipse rx="100" ry="40"></ellipse>
          <ellipse rx="40" ry="100"></ellipse>
          <line x1="-100" y1="0" x2="100" y2="0"></line>
          <circle r="3" fill="var(--color-flame)" stroke="none"></circle>
        </svg>
        <p class="font-display text-2xl text-[var(--color-ink)] sm:text-3xl">
          <span class="italic">Your next world</span> appears here.
        </p>
        <p
          class="max-w-md font-mono text-[11px] uppercase tracking-[0.16em] text-[var(--color-ink-faint)]"
        >
          Drag to look around · pinch to zoom · tilt your phone for gyroscope
        </p>
      </div>

      <div id="gyro-banner" class="absolute right-3 top-3 hidden">
        <button
          id="gyro-btn"
          type="button"
          class="pointer-events-auto bg-[var(--color-ink)] px-3 py-1.5 font-mono text-[10px] uppercase tracking-[0.2em] text-[var(--color-bg)] shadow-lg transition hover:bg-[var(--color-flame)]"
        >
          Enable gyroscope
        </button>
      </div>

      <div
        id="viewer-meta"
        class="pointer-events-none absolute bottom-0 left-0 right-0 hidden bg-gradient-to-t from-black/85 via-black/40 to-transparent p-4 sm:p-5"
      >
        <p
          id="viewer-prompt"
          class="font-display text-base italic text-white sm:text-lg [overflow-wrap:anywhere]"
        >
        </p>
        <div class="mt-3 flex flex-wrap items-center gap-2">
          <button
            id="download-btn"
            type="button"
            class="pointer-events-auto bg-white/10 px-3 py-1.5 font-mono text-[10px] uppercase tracking-[0.2em] text-white backdrop-blur transition hover:bg-[var(--color-flame)]"
          >
            ↓ Download
          </button>
          <button
            id="publish-btn"
            type="button"
            class="pointer-events-auto hidden bg-white/10 px-3 py-1.5 font-mono text-[10px] uppercase tracking-[0.2em] text-white backdrop-blur transition hover:bg-[var(--color-flame)]"
          >
            ↑ Publish to GitHub
          </button>
          <a
            id="published-link"
            href="#"
            target="_blank"
            rel="noreferrer noopener"
            class="pointer-events-auto hidden bg-[var(--color-flame)]/80 px-3 py-1.5 font-mono text-[10px] uppercase tracking-[0.2em] text-white backdrop-blur transition hover:bg-[var(--color-flame)]"
          >
            View shared link ↗
          </a>
        </div>
      </div>
    </section>

    <!-- Gallery -->
    <section>
      <div class="mb-4 flex items-end justify-between gap-3">
        <div class="flex items-baseline gap-3">
          <h2 class="font-display text-2xl tracking-tight sm:text-3xl">Library</h2>
          <span id="gallery-count" class="kicker hidden">— 0 worlds</span>
        </div>
        <button
          id="clear-gallery-btn"
          type="button"
          class="hidden font-mono text-[11px] uppercase tracking-[0.18em] text-[var(--color-ink-faint)] underline decoration-[var(--color-rule)] underline-offset-[5px] transition hover:text-[var(--color-flame)] hover:decoration-[var(--color-flame)]"
        >
          Clear all
        </button>
      </div>
      <div
        id="gallery"
        class="grid grid-cols-2 gap-3 sm:grid-cols-3 sm:gap-4 md:grid-cols-4 lg:grid-cols-5"
      >
      </div>
      <p
        id="gallery-empty"
        class="border border-dashed border-[var(--color-rule)] bg-[var(--color-bg-soft)]/40 px-5 py-10 text-center font-mono text-[11px] uppercase tracking-[0.18em] text-[var(--color-ink-faint)]"
      >
        Empty for now — every world you make lands here.
      </p>
    </section>
  </div>

  <!-- API key modal -->
  <div
    id="key-modal"
    aria-hidden="true"
    class="fixed inset-0 z-[100] hidden items-center justify-center overflow-y-auto bg-black/75 p-4 backdrop-blur-sm"
  >
    <div
      class="my-8 w-full max-w-lg border border-[var(--color-rule)] bg-[var(--color-bg-soft)] p-7 shadow-[0_30px_80px_-30px_rgba(0,0,0,0.8)] sm:p-9"
    >
      <span class="kicker">Bring-your-own-key</span>
      <h2
        id="key-modal-title"
        class="mt-3 font-display text-3xl leading-tight tracking-tight sm:text-4xl"
      >
        Connect your <span class="italic">OpenAI</span> key.
      </h2>
      <p class="mt-3 text-sm leading-relaxed text-[var(--color-ink-soft)]">
        Stored in this browser only. Never logged on our side.
      </p>

      <!-- Tabs -->
      <div
        id="settings-tabs"
        role="tablist"
        aria-label="Settings"
        class="mt-6 flex gap-0 border-b border-[var(--color-rule)]"
      >
        <button
          type="button"
          role="tab"
          data-settings-tab="openai"
          aria-selected="true"
          class="settings-tab -mb-px flex items-center gap-2 border-b-2 border-transparent px-4 py-2.5 font-mono text-[11px] uppercase tracking-[0.18em] text-[var(--color-ink-faint)] transition hover:text-[var(--color-ink)]"
        >
          <span>OpenAI</span>
          <span
            data-tab-check="openai"
            class="hidden size-4 items-center justify-center rounded-full bg-emerald-500 text-[10px] font-bold text-white"
            aria-label="Configured">✓</span
          >
        </button>
        <button
          type="button"
          role="tab"
          data-settings-tab="replicate"
          aria-selected="false"
          class="settings-tab -mb-px flex items-center gap-2 border-b-2 border-transparent px-4 py-2.5 font-mono text-[11px] uppercase tracking-[0.18em] text-[var(--color-ink-faint)] transition hover:text-[var(--color-ink)]"
        >
          <span>Replicate</span>
          <span
            data-tab-check="replicate"
            class="hidden size-4 items-center justify-center rounded-full bg-emerald-500 text-[10px] font-bold text-white"
            aria-label="Configured">✓</span
          >
        </button>
        <button
          type="button"
          role="tab"
          data-settings-tab="github"
          aria-selected="false"
          class="settings-tab -mb-px flex items-center gap-2 border-b-2 border-transparent px-4 py-2.5 font-mono text-[11px] uppercase tracking-[0.18em] text-[var(--color-ink-faint)] transition hover:text-[var(--color-ink)]"
        >
          <span>GitHub</span>
          <span
            data-tab-check="github"
            class="hidden size-4 items-center justify-center rounded-full bg-emerald-500 text-[10px] font-bold text-white"
            aria-label="Configured">✓</span
          >
        </button>
      </div>

      <!-- OpenAI section -->
      <section
        data-tab-panel="openai"
        class="mt-6 border-l-2 border-[var(--color-flame)] bg-[var(--color-flame)]/5 px-4 py-4"
      >
        <p class="kicker text-[var(--color-flame)]">OpenAI</p>
        <p class="mt-1 text-[13px] leading-relaxed text-[var(--color-ink-soft)]">
          Direct API call to <code class="font-mono text-[12px]">api.openai.com</code>. Get a key at
          <a
            class="text-[var(--color-flame)] underline decoration-[var(--color-flame)]/40 underline-offset-[5px] hover:decoration-[var(--color-flame)]"
            href="https://platform.openai.com/api-keys"
            target="_blank"
            rel="noreferrer noopener">platform.openai.com/api-keys</a
          >.
        </p>
        <form id="openai-key-form" class="mt-4 flex flex-col gap-3">
          <label for="openai-key-input" class="kicker">API key</label>
          <input
            id="openai-key-input"
            type="password"
            autocomplete="off"
            spellcheck="false"
            placeholder="sk-..."
            class="border border-[var(--color-rule)] bg-[var(--color-bg)] px-4 py-3 font-mono text-sm text-[var(--color-ink)] placeholder:text-[var(--color-ink-faint)] focus:border-[var(--color-flame)] focus:outline-none"
          />
          <p
            id="openai-key-error"
            class="hidden border-l-2 border-[var(--color-flame)] bg-[var(--color-flame)]/10 px-3 py-2 text-xs text-[var(--color-flame)]"
          >
          </p>
          <div class="flex flex-wrap items-center justify-between gap-2">
            <button
              id="openai-forget-btn"
              type="button"
              class="hidden font-mono text-[11px] uppercase tracking-[0.18em] text-[var(--color-ink-faint)] underline decoration-[var(--color-rule)] underline-offset-[5px] transition hover:text-[var(--color-flame)] hover:decoration-[var(--color-flame)]"
            >
              Forget key
            </button>
            <button
              type="submit"
              class="bg-[var(--color-ink)] px-5 py-2 font-mono text-[11px] uppercase tracking-[0.2em] text-[var(--color-bg)] transition hover:bg-[var(--color-flame)] disabled:opacity-60"
            >
              Save OpenAI key
            </button>
          </div>
        </form>
      </section>

      <!-- GitHub publish section -->
      <section
        data-tab-panel="github"
        class="mt-4 border-l-2 border-[var(--color-rule)] bg-[var(--color-bg)]/60 px-4 py-4"
      >
        <p class="kicker">GitHub publish (optional)</p>
        <p class="mt-1 text-[13px] leading-relaxed text-[var(--color-ink-soft)]">
          Publish your worlds to a public GitHub repo so you can share them via
          <code class="font-mono text-[12px]">360world.yoandev.co/u/&lt;you&gt;</code>.
        </p>
        <ol
          class="mt-3 list-decimal space-y-1.5 pl-5 text-[13px] leading-relaxed text-[var(--color-ink-soft)] marker:font-mono marker:text-[var(--color-flame)]"
        >
          <li>
            <a
              class="text-[var(--color-flame)] underline decoration-[var(--color-flame)]/40 underline-offset-[4px] hover:decoration-[var(--color-flame)]"
              href="https://github.com/new"
              target="_blank"
              rel="noreferrer noopener">Create a new GitHub repo</a
            > named <strong><code class="font-mono text-[12px]">360world-data</code></strong>, set
            it to <strong>Public</strong>, and <strong>tick "Add a README file"</strong> so the repo has
            an initial commit (otherwise the first publish starts from a blank branch).
          </li>
          <li>
            <a
              class="text-[var(--color-flame)] underline decoration-[var(--color-flame)]/40 underline-offset-[4px] hover:decoration-[var(--color-flame)]"
              href="https://github.com/settings/personal-access-tokens/new"
              target="_blank"
              rel="noreferrer noopener">Generate a Fine-grained PAT</a
            > — under <em>Repository access</em> pick <strong>Only select repositories</strong> and choose
            <code class="font-mono text-[12px]">360world-data</code>. Under
            <em>Permissions</em> → Repository, grant
            <strong><span class="font-mono">Contents: Read and write</span></strong>.
          </li>
          <li>
            Paste your GitHub username and the PAT below, then hit
            <strong>Test &amp; save</strong>. The token stays in this browser (IndexedDB) — it never
            leaves your machine.
          </li>
        </ol>
        <div
          id="github-profile-link-wrapper"
          class="mt-3 hidden flex-col gap-2 border-l-2 border-emerald-500/70 bg-emerald-500/5 px-3 py-2 sm:flex-row sm:items-center sm:justify-between"
        >
          <div class="min-w-0 flex-1">
            <p class="kicker text-emerald-400">Your public gallery</p>
            <a
              id="github-profile-link"
              href="#"
              target="_blank"
              rel="noreferrer noopener"
              class="block truncate font-mono text-[12px] text-[var(--color-ink)] underline decoration-[var(--color-rule)] underline-offset-[4px] hover:text-[var(--color-flame)] hover:decoration-[var(--color-flame)]"
            >
            </a>
          </div>
          <button
            id="github-profile-copy"
            type="button"
            class="shrink-0 border border-[var(--color-rule)] bg-[var(--color-bg)] px-3 py-1.5 font-mono text-[10px] uppercase tracking-[0.18em] text-[var(--color-ink)] transition hover:border-[var(--color-flame)] hover:text-[var(--color-flame)]"
          >
            Copy link
          </button>
        </div>
        <form id="github-form" class="mt-4 flex flex-col gap-3">
          <label for="github-username-input" class="kicker">GitHub username</label>
          <input
            id="github-username-input"
            type="text"
            autocomplete="off"
            spellcheck="false"
            placeholder="octocat"
            class="border border-[var(--color-rule)] bg-[var(--color-bg)] px-4 py-3 font-mono text-sm text-[var(--color-ink)] placeholder:text-[var(--color-ink-faint)] focus:border-[var(--color-flame)] focus:outline-none"
          />
          <label for="github-pat-input" class="kicker">Fine-grained PAT</label>
          <input
            id="github-pat-input"
            type="password"
            autocomplete="off"
            spellcheck="false"
            placeholder="github_pat_..."
            class="border border-[var(--color-rule)] bg-[var(--color-bg)] px-4 py-3 font-mono text-sm text-[var(--color-ink)] placeholder:text-[var(--color-ink-faint)] focus:border-[var(--color-flame)] focus:outline-none"
          />
          <p
            id="github-error"
            class="hidden border-l-2 border-[var(--color-flame)] bg-[var(--color-flame)]/10 px-3 py-2 text-xs text-[var(--color-flame)]"
          >
          </p>
          <p
            id="github-success"
            class="hidden border-l-2 border-emerald-500 bg-emerald-500/10 px-3 py-2 text-xs text-emerald-400"
          >
          </p>
          <div class="flex flex-wrap items-center justify-between gap-2">
            <button
              id="github-forget-btn"
              type="button"
              class="hidden font-mono text-[11px] uppercase tracking-[0.18em] text-[var(--color-ink-faint)] underline decoration-[var(--color-rule)] underline-offset-[5px] transition hover:text-[var(--color-flame)] hover:decoration-[var(--color-flame)]"
            >
              Disconnect GitHub
            </button>
            <button
              type="submit"
              class="bg-[var(--color-ink)] px-5 py-2 font-mono text-[11px] uppercase tracking-[0.2em] text-[var(--color-bg)] transition hover:bg-[var(--color-flame)] disabled:opacity-60"
            >
              Test &amp; save
            </button>
          </div>
        </form>
      </section>

      <!-- Replicate section -->
      <section
        data-tab-panel="replicate"
        class="mt-4 border-l-2 border-[var(--color-rule)] bg-[var(--color-bg)]/60 px-4 py-4"
      >
        <p class="kicker">Replicate</p>
        <p class="mt-1 text-[13px] leading-relaxed text-[var(--color-ink-soft)]">
          Routed through a CORS proxy (Netlify function). Get a key at
          <a
            class="text-[var(--color-flame)] underline decoration-[var(--color-flame)]/40 underline-offset-[5px] hover:decoration-[var(--color-flame)]"
            href="https://replicate.com/account/api-tokens"
            target="_blank"
            rel="noreferrer noopener">replicate.com/account/api-tokens</a
          >.
        </p>
        <form id="replicate-key-form" class="mt-4 flex flex-col gap-3">
          <label for="replicate-key-input" class="kicker">API token</label>
          <input
            id="replicate-key-input"
            type="password"
            autocomplete="off"
            spellcheck="false"
            placeholder="r8_..."
            class="border border-[var(--color-rule)] bg-[var(--color-bg)] px-4 py-3 font-mono text-sm text-[var(--color-ink)] placeholder:text-[var(--color-ink-faint)] focus:border-[var(--color-flame)] focus:outline-none"
          />
          <p
            id="replicate-key-error"
            class="hidden border-l-2 border-[var(--color-flame)] bg-[var(--color-flame)]/10 px-3 py-2 text-xs text-[var(--color-flame)]"
          >
          </p>
          <div class="flex flex-wrap items-center justify-between gap-2">
            <button
              id="replicate-forget-btn"
              type="button"
              class="hidden font-mono text-[11px] uppercase tracking-[0.18em] text-[var(--color-ink-faint)] underline decoration-[var(--color-rule)] underline-offset-[5px] transition hover:text-[var(--color-flame)] hover:decoration-[var(--color-flame)]"
            >
              Forget key
            </button>
            <button
              type="submit"
              class="bg-[var(--color-ink)] px-5 py-2 font-mono text-[11px] uppercase tracking-[0.2em] text-[var(--color-bg)] transition hover:bg-[var(--color-flame)] disabled:opacity-60"
            >
              Save Replicate key
            </button>
          </div>
        </form>
      </section>

      <p
        class="mt-5 font-mono text-[10px] uppercase tracking-[0.16em] text-[var(--color-ink-faint)]"
      >
        ⚠ Stored locally — don't use this app on a shared device.
      </p>

      <div class="mt-5 flex justify-end">
        <button
          id="key-cancel-btn"
          type="button"
          class="hidden border border-[var(--color-rule)] bg-transparent px-5 py-2.5 font-mono text-[11px] uppercase tracking-[0.2em] text-[var(--color-ink)] transition hover:border-[var(--color-ink)]"
        >
          Close
        </button>
      </div>
    </div>
  </div>

  <!-- Toast -->
  <div
    id="toast"
    role="status"
    aria-live="polite"
    class="pointer-events-none fixed bottom-6 left-1/2 z-[110] hidden -translate-x-1/2 border border-[var(--color-ink)] bg-[var(--color-ink)] px-4 py-2 font-mono text-[11px] uppercase tracking-[0.18em] text-[var(--color-bg)] shadow-2xl"
  >
  </div>

  <script>
    import {
      apiKeyStore,
      githubConfigStore,
      imagesStore,
      openaiApiKeyStore,
      preferencesStore,
      type Provider,
      type StoredImage,
    } from "../lib/storage";
    import { fetchImageBlob, generate360Image as generateReplicateImage } from "../lib/replicate";
    import {
      OPENAI_QUALITY_OPTIONS,
      OPENAI_SIZE_OPTIONS,
      generate360Image as generateOpenAIImage,
      type OpenAIImageQuality,
      type OpenAIImageSize,
    } from "../lib/openai";
    import { downloadBlob, suggestedFilename } from "../lib/download";
    import { toEquirectangularBlob } from "../lib/equirect";
    import { buildThumbnail } from "../lib/thumbnail";
    import {
      publishImage,
      siteGalleryUrl,
      siteViewerUrl,
      unpublishImage,
      validateConfig,
    } from "../lib/github";

    type ViewerCtor = typeof import("@photo-sphere-viewer/core").Viewer;
    type GyroPlugin = import("@photo-sphere-viewer/gyroscope-plugin").GyroscopePlugin;

    const $ = <T extends HTMLElement>(id: string): T => {
      const el = document.getElementById(id);
      if (!el) throw new Error(`Missing #${id}`);
      return el as T;
    };

    const els = {
      promptForm: $<HTMLFormElement>("prompt-form"),
      promptInput: $<HTMLTextAreaElement>("prompt-input"),
      generateBtn: $<HTMLButtonElement>("generate-btn"),
      generateLabel: $<HTMLSpanElement>("generate-label"),
      generateSpinner: $<HTMLSpanElement>("generate-spinner"),
      providerSwitch: $<HTMLDivElement>("provider-switch"),
      providerSwitchWrapper: $<HTMLDivElement>("provider-switch-wrapper"),
      openaiOptions: $<HTMLDivElement>("openai-options"),
      openaiSize: $<HTMLSelectElement>("openai-size"),
      openaiQuality: $<HTMLSelectElement>("openai-quality"),
      viewerSection: $<HTMLElement>("viewer-section"),
      viewer: $<HTMLDivElement>("viewer"),
      viewerEmpty: $<HTMLDivElement>("viewer-empty"),
      viewerMeta: $<HTMLDivElement>("viewer-meta"),
      viewerPrompt: $<HTMLParagraphElement>("viewer-prompt"),
      downloadBtn: $<HTMLButtonElement>("download-btn"),
      gyroBanner: $<HTMLDivElement>("gyro-banner"),
      gyroBtn: $<HTMLButtonElement>("gyro-btn"),
      gallery: $<HTMLDivElement>("gallery"),
      galleryEmpty: $<HTMLParagraphElement>("gallery-empty"),
      galleryCount: $<HTMLSpanElement>("gallery-count"),
      clearGalleryBtn: $<HTMLButtonElement>("clear-gallery-btn"),
      settingsBtn: $<HTMLButtonElement>("settings-btn"),
      keyModal: $<HTMLDivElement>("key-modal"),
      keyModalTitle: $<HTMLHeadingElement>("key-modal-title"),
      openaiKeyForm: $<HTMLFormElement>("openai-key-form"),
      openaiKeyInput: $<HTMLInputElement>("openai-key-input"),
      openaiKeyError: $<HTMLParagraphElement>("openai-key-error"),
      openaiForget: $<HTMLButtonElement>("openai-forget-btn"),
      replicateKeyForm: $<HTMLFormElement>("replicate-key-form"),
      replicateKeyInput: $<HTMLInputElement>("replicate-key-input"),
      replicateKeyError: $<HTMLParagraphElement>("replicate-key-error"),
      replicateForget: $<HTMLButtonElement>("replicate-forget-btn"),
      githubForm: $<HTMLFormElement>("github-form"),
      githubUsername: $<HTMLInputElement>("github-username-input"),
      githubPat: $<HTMLInputElement>("github-pat-input"),
      githubProfileLinkWrapper: $<HTMLDivElement>("github-profile-link-wrapper"),
      githubProfileLink: $<HTMLAnchorElement>("github-profile-link"),
      githubProfileCopy: $<HTMLButtonElement>("github-profile-copy"),
      myGalleryLink: $<HTMLAnchorElement>("my-gallery-link"),
      githubError: $<HTMLParagraphElement>("github-error"),
      githubSuccess: $<HTMLParagraphElement>("github-success"),
      githubForget: $<HTMLButtonElement>("github-forget-btn"),
      publishBtn: $<HTMLButtonElement>("publish-btn"),
      publishedLink: $<HTMLAnchorElement>("published-link"),
      keyCancel: $<HTMLButtonElement>("key-cancel-btn"),
      toast: $<HTMLDivElement>("toast"),
    };

    type SettingsTab = "openai" | "replicate" | "github";
    const settingsTabBtns = Array.from(
      document.querySelectorAll<HTMLButtonElement>("[data-settings-tab]"),
    );
    const settingsTabPanels = Array.from(
      document.querySelectorAll<HTMLElement>("[data-tab-panel]"),
    );
    const settingsTabChecks = new Map<SettingsTab, HTMLElement>();
    for (const check of document.querySelectorAll<HTMLElement>("[data-tab-check]")) {
      settingsTabChecks.set(check.dataset.tabCheck as SettingsTab, check);
    }

    const providerTabs = Array.from(
      els.providerSwitch.querySelectorAll<HTMLButtonElement>(".provider-tab"),
    );

    function selectSettingsTab(tab: SettingsTab): void {
      for (const btn of settingsTabBtns) {
        const isActive = btn.dataset.settingsTab === tab;
        btn.setAttribute("aria-selected", isActive ? "true" : "false");
        btn.style.color = isActive ? "var(--color-ink)" : "var(--color-ink-faint)";
        btn.style.borderColor = isActive ? "var(--color-flame)" : "transparent";
      }
      for (const panel of settingsTabPanels) {
        const isActive = panel.dataset.tabPanel === tab;
        panel.classList.toggle("hidden", !isActive);
      }
    }

    function updateSettingsTabChecks(state: {
      openai: boolean;
      replicate: boolean;
      github: boolean;
    }): void {
      for (const [tab, check] of settingsTabChecks) {
        const active = state[tab];
        check.classList.toggle("hidden", !active);
        check.classList.toggle("flex", active);
      }
    }

    async function refreshSettingsTabChecks(): Promise<void> {
      const [openaiKey, replicateKey, github] = await Promise.all([
        openaiApiKeyStore.get(),
        apiKeyStore.get(),
        githubConfigStore.get(),
      ]);
      updateSettingsTabChecks({
        openai: Boolean(openaiKey),
        replicate: Boolean(replicateKey),
        github: Boolean(github),
      });
    }

    async function refreshGithubProfileUI(): Promise<void> {
      const github = await githubConfigStore.get();
      if (!github) {
        els.myGalleryLink.classList.add("hidden");
        els.githubProfileLinkWrapper.classList.add("hidden");
        els.githubProfileLinkWrapper.classList.remove("flex");
        return;
      }
      const relPath = siteGalleryUrl(github.username);
      const absUrl = `${window.location.origin}${relPath}`;
      els.myGalleryLink.href = relPath;
      els.myGalleryLink.classList.remove("hidden");
      els.githubProfileLink.href = relPath;
      els.githubProfileLink.textContent = absUrl;
      els.githubProfileLinkWrapper.classList.remove("hidden");
      els.githubProfileLinkWrapper.classList.add("flex");
    }

    let currentProvider: Provider = "openai";

    let viewerInstance: InstanceType<ViewerCtor> | null = null;
    let viewerObjectUrl: string | null = null;
    let currentImage: StoredImage | null = null;
    let toastTimer: number | null = null;
    let viewerModule: typeof import("@photo-sphere-viewer/core") | null = null;
    let gyroModule: typeof import("@photo-sphere-viewer/gyroscope-plugin") | null = null;

    async function loadViewerModules(): Promise<void> {
      if (viewerModule && gyroModule) return;
      [viewerModule, gyroModule] = await Promise.all([
        import("@photo-sphere-viewer/core"),
        import("@photo-sphere-viewer/gyroscope-plugin"),
      ]);
    }

    function showToast(message: string, kind: "info" | "error" = "info"): void {
      els.toast.textContent = message;
      els.toast.classList.remove("hidden");
      els.toast.style.background =
        kind === "error" ? "var(--color-flame-deep)" : "var(--color-ink)";
      els.toast.style.color = kind === "error" ? "var(--color-ink)" : "var(--color-bg)";
      els.toast.style.borderColor =
        kind === "error" ? "var(--color-flame-deep)" : "var(--color-ink)";
      if (toastTimer) window.clearTimeout(toastTimer);
      toastTimer = window.setTimeout(() => els.toast.classList.add("hidden"), 4500);
    }

    function setBusy(busy: boolean, label = "Generating…"): void {
      els.generateBtn.disabled = busy;
      els.promptInput.disabled = busy;
      els.generateLabel.textContent = busy ? label : "Generate →";
      els.generateSpinner.classList.toggle("hidden", !busy);
    }

    async function openModal(mode: "onboarding" | "settings"): Promise<void> {
      els.keyModal.classList.remove("hidden");
      els.keyModal.classList.add("flex");
      els.keyModal.setAttribute("aria-hidden", "false");
      els.openaiKeyError.classList.add("hidden");
      els.replicateKeyError.classList.add("hidden");
      els.githubError.classList.add("hidden");
      els.githubSuccess.classList.add("hidden");
      els.openaiKeyInput.value = "";
      els.replicateKeyInput.value = "";
      els.githubPat.value = "";

      const [hasOpenaiKey, hasReplicateKey, githubConfig] = await Promise.all([
        openaiApiKeyStore.get(),
        apiKeyStore.get(),
        githubConfigStore.get(),
      ]);
      els.openaiForget.classList.toggle("hidden", !hasOpenaiKey);
      els.replicateForget.classList.toggle("hidden", !hasReplicateKey);
      els.githubForget.classList.toggle("hidden", !githubConfig);
      if (githubConfig) {
        els.githubUsername.value = githubConfig.username;
      } else {
        els.githubUsername.value = "";
      }

      const isSettings = mode === "settings";
      els.keyCancel.classList.toggle("hidden", !isSettings);

      updateSettingsTabChecks({
        openai: Boolean(hasOpenaiKey),
        replicate: Boolean(hasReplicateKey),
        github: Boolean(githubConfig),
      });
      const initialTab: SettingsTab = mode === "onboarding" ? currentProvider : currentProvider;
      selectSettingsTab(initialTab);

      els.keyModalTitle.innerHTML = isSettings
        ? "Settings"
        : 'Connect a key to get <span class="italic">started</span>.';

      setTimeout(() => {
        const target = currentProvider === "openai" ? els.openaiKeyInput : els.replicateKeyInput;
        target.focus();
      }, 50);
    }

    function closeModal(): void {
      els.keyModal.classList.add("hidden");
      els.keyModal.classList.remove("flex");
      els.keyModal.setAttribute("aria-hidden", "true");
    }

    async function getActiveKey(): Promise<string | null> {
      return currentProvider === "openai" ? openaiApiKeyStore.get() : apiKeyStore.get();
    }

    async function ensureKey(): Promise<string | null> {
      const key = await getActiveKey();
      if (!key) {
        await openModal("onboarding");
        return null;
      }
      return key;
    }

    function populateOpenAIOptions(): void {
      for (const opt of OPENAI_SIZE_OPTIONS) {
        const el = document.createElement("option");
        el.value = opt.value;
        el.textContent = opt.label;
        els.openaiSize.appendChild(el);
      }
      for (const opt of OPENAI_QUALITY_OPTIONS) {
        const el = document.createElement("option");
        el.value = opt.value;
        el.textContent = opt.label;
        els.openaiQuality.appendChild(el);
      }
    }

    function applyProviderUI(): void {
      for (const tab of providerTabs) {
        const isActive = tab.dataset.provider === currentProvider;
        tab.setAttribute("aria-selected", isActive ? "true" : "false");
        tab.style.background = isActive ? "var(--color-ink)" : "transparent";
        tab.style.color = isActive ? "var(--color-bg)" : "var(--color-ink)";
      }
      els.openaiOptions.classList.toggle("hidden", currentProvider !== "openai");
    }

    async function refreshProviderSwitchVisibility(): Promise<void> {
      const [openaiKey, replicateKey] = await Promise.all([
        openaiApiKeyStore.get(),
        apiKeyStore.get(),
      ]);
      const bothPresent = Boolean(openaiKey) && Boolean(replicateKey);
      els.providerSwitchWrapper.classList.toggle("hidden", !bothPresent);
      els.providerSwitchWrapper.classList.toggle("flex", bothPresent);
    }

    async function switchProvider(next: Provider): Promise<void> {
      if (next === currentProvider) return;
      currentProvider = next;
      await preferencesStore.setProvider(next);
      applyProviderUI();
    }

    async function alignProviderWithAvailableKeys(): Promise<void> {
      const [openaiKey, replicateKey] = await Promise.all([
        openaiApiKeyStore.get(),
        apiKeyStore.get(),
      ]);
      // If only one provider has a key, force-activate it regardless of the
      // stored preference — otherwise "Generate" would hit a missing key.
      if (openaiKey && !replicateKey && currentProvider !== "openai") {
        await switchProvider("openai");
      } else if (replicateKey && !openaiKey && currentProvider !== "replicate") {
        await switchProvider("replicate");
      }
    }

    function isMobile(): boolean {
      return window.matchMedia("(pointer: coarse)").matches;
    }

    async function showImage(image: StoredImage): Promise<void> {
      currentImage = image;
      await loadViewerModules();
      const { Viewer } = viewerModule!;
      const { GyroscopePlugin } = gyroModule!;

      if (viewerObjectUrl) {
        URL.revokeObjectURL(viewerObjectUrl);
        viewerObjectUrl = null;
      }
      const equirectBlob = await toEquirectangularBlob(image.blob, {
        type: image.contentType,
      });
      viewerObjectUrl = URL.createObjectURL(equirectBlob);

      els.viewerEmpty.classList.add("hidden");
      els.viewerMeta.classList.remove("hidden");
      els.viewerPrompt.textContent = image.prompt;
      if (isMobile()) {
        els.gyroBanner.classList.remove("hidden");
      }

      if (viewerInstance) {
        viewerInstance.destroy();
        viewerInstance = null;
      }

      viewerInstance = new Viewer({
        container: els.viewer,
        panorama: viewerObjectUrl,
        navbar: ["zoom", "move", "fullscreen"],
        defaultPitch: 0,
        defaultYaw: 0,
        plugins: [[GyroscopePlugin, { touchmove: true }]],
      });

      await refreshPublishState();
    }

    function destroyViewer(): void {
      if (viewerInstance) {
        viewerInstance.destroy();
        viewerInstance = null;
      }
      if (viewerObjectUrl) {
        URL.revokeObjectURL(viewerObjectUrl);
        viewerObjectUrl = null;
      }
      currentImage = null;
      els.viewerEmpty.classList.remove("hidden");
      els.viewerMeta.classList.add("hidden");
      els.gyroBanner.classList.add("hidden");
    }

    async function refreshGallery(): Promise<void> {
      const [items, githubConfig] = await Promise.all([
        imagesStore.list(),
        githubConfigStore.get(),
      ]);
      const hasGithub = Boolean(githubConfig);
      els.gallery.innerHTML = "";
      if (items.length === 0) {
        els.galleryEmpty.classList.remove("hidden");
        els.clearGalleryBtn.classList.add("hidden");
        els.galleryCount.classList.add("hidden");
        return;
      }
      els.galleryEmpty.classList.add("hidden");
      els.clearGalleryBtn.classList.remove("hidden");
      els.galleryCount.classList.remove("hidden");
      els.galleryCount.textContent = `— ${items.length} world${items.length > 1 ? "s" : ""}`;

      const fragment = document.createDocumentFragment();
      for (const item of items) {
        const card = document.createElement("article");
        card.className =
          "group relative overflow-hidden border border-[var(--color-rule)] bg-[var(--color-bg-soft)] transition hover:border-[var(--color-flame)] cursor-pointer";

        const img = document.createElement("img");
        const objectUrl = URL.createObjectURL(item.blob);
        img.src = objectUrl;
        img.alt = item.prompt;
        img.loading = "lazy";
        img.className = "aspect-[3/2] w-full object-cover transition group-hover:scale-[1.02]";
        img.addEventListener("load", () => URL.revokeObjectURL(objectUrl), { once: true });

        const overlay = document.createElement("div");
        overlay.className =
          "pointer-events-none absolute inset-0 flex flex-col justify-end bg-gradient-to-t from-black/85 via-black/0 to-transparent p-3 opacity-0 transition group-hover:opacity-100";
        const caption = document.createElement("p");
        caption.className = "line-clamp-2 font-display text-[13px] italic text-white sm:text-sm";
        caption.textContent = item.prompt;
        overlay.appendChild(caption);

        const actions = document.createElement("div");
        actions.className = "pointer-events-auto absolute right-2 top-2 flex gap-1.5";

        const downloadBtn = document.createElement("button");
        downloadBtn.type = "button";
        downloadBtn.title = "Download";
        downloadBtn.className =
          "bg-[var(--color-bg)]/85 px-2 py-1 font-mono text-[10px] text-[var(--color-ink)] backdrop-blur transition hover:bg-[var(--color-flame)] hover:text-[var(--color-bg)]";
        downloadBtn.textContent = "↓";
        downloadBtn.addEventListener("click", (e) => {
          e.stopPropagation();
          downloadBlob(item.blob, suggestedFilename(item.prompt));
        });

        const removeBtn = document.createElement("button");
        removeBtn.type = "button";
        removeBtn.title = "Remove";
        removeBtn.className =
          "bg-[var(--color-bg)]/85 px-2 py-1 font-mono text-[10px] text-[var(--color-ink)] backdrop-blur transition hover:bg-[var(--color-flame-deep)] hover:text-[var(--color-ink)]";
        removeBtn.textContent = "✕";
        removeBtn.addEventListener("click", async (e) => {
          e.stopPropagation();
          await imagesStore.remove(item.id);
          if (currentImage?.id === item.id) destroyViewer();
          await refreshGallery();
        });

        actions.appendChild(downloadBtn);
        if (hasGithub) {
          const publishBtn = document.createElement("button");
          publishBtn.type = "button";
          publishBtn.title = item.publishedSlug ? "Unpublish from GitHub" : "Publish to GitHub";
          publishBtn.className = item.publishedSlug
            ? "bg-emerald-500/90 px-2 py-1 font-mono text-[10px] text-white backdrop-blur transition hover:bg-[var(--color-flame-deep)]"
            : "bg-[var(--color-bg)]/85 px-2 py-1 font-mono text-[10px] text-[var(--color-ink)] backdrop-blur transition hover:bg-[var(--color-flame)] hover:text-[var(--color-bg)]";
          publishBtn.textContent = item.publishedSlug ? "✓" : "↑";
          publishBtn.addEventListener("click", async (e) => {
            e.stopPropagation();
            publishBtn.disabled = true;
            publishBtn.textContent = "…";
            try {
              await togglePublishImage(item);
            } catch (err) {
              showToast((err as Error).message ?? "Publish failed.", "error");
            } finally {
              await refreshGallery();
              if (currentImage?.id === item.id) await refreshPublishState();
            }
          });
          actions.appendChild(publishBtn);
        }
        actions.appendChild(removeBtn);

        card.appendChild(img);
        card.appendChild(overlay);
        card.appendChild(actions);
        card.addEventListener("click", () => {
          void showImage(item);
          els.viewerSection.scrollIntoView({ behavior: "smooth", block: "start" });
        });
        fragment.appendChild(card);
      }
      els.gallery.appendChild(fragment);
    }

    async function handleGenerate(event: SubmitEvent): Promise<void> {
      event.preventDefault();
      const prompt = els.promptInput.value.trim();
      if (!prompt) return;
      const key = await ensureKey();
      if (!key) return;

      setBusy(true, "Starting…");
      try {
        let stored: StoredImage;
        if (currentProvider === "openai") {
          const size = els.openaiSize.value as OpenAIImageSize;
          const quality = els.openaiQuality.value as OpenAIImageQuality;
          setBusy(true, "Painting…");
          const generated = await generateOpenAIImage({
            apiKey: key,
            prompt,
            size,
            quality,
          });
          stored = await imagesStore.add({
            prompt: generated.prompt,
            finalPrompt: generated.finalPrompt,
            blob: generated.blob,
            contentType: generated.blob.type || "image/png",
          });
        } else {
          const generated = await generateReplicateImage({
            apiKey: key,
            prompt,
            onProgress: (e) => {
              const seconds = Math.round(e.elapsedMs / 1000);
              const verb = e.status === "starting" ? "Warming up" : "Painting";
              setBusy(true, `${verb} · ${seconds}s`);
            },
          });
          setBusy(true, "Downloading…");
          const blob = await fetchImageBlob(generated.url);
          stored = await imagesStore.add({
            prompt: generated.prompt,
            finalPrompt: generated.finalPrompt,
            blob,
            contentType: blob.type || "image/webp",
          });
        }

        await refreshGallery();
        await showImage(stored);
        els.promptInput.value = "";
        showToast("World ready — drag to explore.");
      } catch (error) {
        const err = error as Error;
        if (err.name === "InvalidApiKeyError" || err.name === "InvalidOpenAIKeyError") {
          await openModal("settings");
        }
        showToast(err.message ?? "Generation failed.", "error");
      } finally {
        setBusy(false);
      }
    }

    async function handleSaveProviderKey(provider: Provider, event: SubmitEvent): Promise<void> {
      event.preventDefault();
      const input = provider === "openai" ? els.openaiKeyInput : els.replicateKeyInput;
      const errorEl = provider === "openai" ? els.openaiKeyError : els.replicateKeyError;
      const forgetBtn = provider === "openai" ? els.openaiForget : els.replicateForget;
      const store = provider === "openai" ? openaiApiKeyStore : apiKeyStore;
      const submit = (event.submitter as HTMLButtonElement | null) ?? null;
      const value = input.value.trim();
      if (!value) return;
      if (submit) submit.disabled = true;
      try {
        await store.set(value);
        errorEl.classList.add("hidden");
        forgetBtn.classList.remove("hidden");
        input.value = "";
        // If the user saved a key for a provider other than the active one,
        // auto-switch — that's almost certainly what they meant.
        if (provider !== currentProvider) {
          await switchProvider(provider);
        }
        await refreshProviderSwitchVisibility();
        await refreshSettingsTabChecks();
        closeModal();
        showToast(
          provider === "openai" ? "OpenAI key saved locally." : "Replicate key saved locally.",
        );
      } catch (error) {
        const err = error as Error;
        errorEl.textContent = err.message;
        errorEl.classList.remove("hidden");
      } finally {
        if (submit) submit.disabled = false;
      }
    }

    async function enableGyroscope(): Promise<void> {
      if (!viewerInstance || !gyroModule) return;
      const plugin = viewerInstance.getPlugin(gyroModule.GyroscopePlugin) as GyroPlugin | null;
      if (!plugin) {
        showToast("Gyroscope plugin not available.", "error");
        return;
      }
      try {
        await plugin.start();
        els.gyroBtn.textContent = "Gyroscope on";
      } catch (error) {
        const err = error as Error;
        showToast(err.message ?? "Could not enable gyroscope.", "error");
      }
    }

    async function handleSaveGithub(event: SubmitEvent): Promise<void> {
      event.preventDefault();
      const username = els.githubUsername.value.trim();
      const pat = els.githubPat.value.trim();
      const submit = (event.submitter as HTMLButtonElement | null) ?? null;
      els.githubError.classList.add("hidden");
      els.githubSuccess.classList.add("hidden");
      if (!username || !pat) {
        els.githubError.textContent = "Fill both fields.";
        els.githubError.classList.remove("hidden");
        return;
      }
      if (submit) {
        submit.disabled = true;
        submit.textContent = "Testing…";
      }
      try {
        const result = await validateConfig({ username, pat });
        if (!result.ok) {
          els.githubError.textContent = result.reason;
          els.githubError.classList.remove("hidden");
          return;
        }
        await githubConfigStore.set({ username, pat });
        els.githubPat.value = "";
        els.githubForget.classList.remove("hidden");
        els.githubSuccess.textContent = `Connected as @${result.login}.`;
        els.githubSuccess.classList.remove("hidden");
        await refreshPublishState();
        await refreshGallery();
        await refreshSettingsTabChecks();
        await refreshGithubProfileUI();
        showToast("GitHub publishing enabled.");
      } finally {
        if (submit) {
          submit.disabled = false;
          submit.textContent = "Test & save";
        }
      }
    }

    async function refreshPublishState(): Promise<void> {
      const config = await githubConfigStore.get();
      const hasConfig = Boolean(config);
      if (!currentImage || !hasConfig) {
        els.publishBtn.classList.add("hidden");
        els.publishedLink.classList.add("hidden");
        return;
      }
      if (currentImage.publishedSlug) {
        els.publishBtn.classList.remove("hidden");
        els.publishBtn.textContent = "✕ Unpublish";
        els.publishedLink.href = siteViewerUrl(config!.username, currentImage.publishedSlug);
        els.publishedLink.classList.remove("hidden");
      } else {
        els.publishBtn.classList.remove("hidden");
        els.publishBtn.textContent = "↑ Publish to GitHub";
        els.publishedLink.classList.add("hidden");
      }
    }

    type PublishProgress = (label: string) => void;

    async function togglePublishImage(
      image: StoredImage,
      onProgress?: PublishProgress,
    ): Promise<void> {
      const config = await githubConfigStore.get();
      if (!config) {
        await openModal("settings");
        selectSettingsTab("github");
        return;
      }
      if (image.publishedSlug) {
        onProgress?.("Unpublishing…");
        await unpublishImage(config, image.publishedSlug);
        await imagesStore.setPublishedSlug(image.id, null);
        image.publishedSlug = undefined;
        showToast("Unpublished.");
      } else {
        onProgress?.("Preparing thumbnail…");
        const equirect = await toEquirectangularBlob(image.blob, {
          type: image.contentType,
        });
        const thumb = await buildThumbnail(equirect);
        onProgress?.("Uploading to GitHub…");
        const result = await publishImage(config, {
          image: equirect,
          thumbnail: thumb,
          prompt: image.prompt,
          finalPrompt: image.finalPrompt,
          createdAt: image.createdAt,
        });
        await imagesStore.setPublishedSlug(image.id, result.slug);
        image.publishedSlug = result.slug;
        showToast(`Published — ${window.location.origin}${result.viewerUrl}`);
      }
    }

    async function handlePublishCurrent(): Promise<void> {
      if (!currentImage) return;
      const image = currentImage;
      els.publishBtn.disabled = true;
      const original = els.publishBtn.textContent;
      try {
        await togglePublishImage(image, (label) => {
          els.publishBtn.textContent = label;
        });
      } catch (err) {
        const e = err as Error;
        showToast(e.message ?? "Publish failed.", "error");
        els.publishBtn.textContent = original ?? "↑ Publish to GitHub";
      } finally {
        els.publishBtn.disabled = false;
        await refreshPublishState();
        await refreshGallery();
      }
    }

    els.promptForm.addEventListener("submit", handleGenerate);
    els.openaiKeyForm.addEventListener("submit", (e) => handleSaveProviderKey("openai", e));
    els.replicateKeyForm.addEventListener("submit", (e) => handleSaveProviderKey("replicate", e));
    for (const btn of settingsTabBtns) {
      btn.addEventListener("click", () => {
        const tab = btn.dataset.settingsTab as SettingsTab | undefined;
        if (tab) selectSettingsTab(tab);
      });
    }
    els.githubForm.addEventListener("submit", (e) => handleSaveGithub(e));
    els.githubForget.addEventListener("click", async () => {
      await githubConfigStore.clear();
      els.githubForget.classList.add("hidden");
      els.githubSuccess.classList.add("hidden");
      await refreshPublishState();
      await refreshGallery();
      await refreshSettingsTabChecks();
      await refreshGithubProfileUI();
      showToast("GitHub config removed from this browser.");
    });
    els.githubProfileCopy.addEventListener("click", async () => {
      const url = els.githubProfileLink.textContent?.trim();
      if (!url) return;
      try {
        await navigator.clipboard.writeText(url);
        showToast("Link copied to clipboard.");
      } catch {
        showToast("Could not copy — select the link and copy manually.", "error");
      }
    });
    els.publishBtn.addEventListener("click", () => void handlePublishCurrent());
    els.settingsBtn.addEventListener("click", () => {
      void openModal("settings");
    });
    els.keyCancel.addEventListener("click", closeModal);
    els.openaiForget.addEventListener("click", async () => {
      await openaiApiKeyStore.clear();
      els.openaiForget.classList.add("hidden");
      await alignProviderWithAvailableKeys();
      await refreshProviderSwitchVisibility();
      await refreshSettingsTabChecks();
      showToast("OpenAI key removed from this browser.");
    });
    els.replicateForget.addEventListener("click", async () => {
      await apiKeyStore.clear();
      els.replicateForget.classList.add("hidden");
      await alignProviderWithAvailableKeys();
      await refreshProviderSwitchVisibility();
      await refreshSettingsTabChecks();
      showToast("Replicate key removed from this browser.");
    });
    for (const tab of providerTabs) {
      tab.addEventListener("click", () => {
        const next = tab.dataset.provider as Provider | undefined;
        if (next) void switchProvider(next);
      });
    }
    els.openaiSize.addEventListener("change", () => {
      void preferencesStore.setOpenAISize(els.openaiSize.value as OpenAIImageSize);
    });
    els.openaiQuality.addEventListener("change", () => {
      void preferencesStore.setOpenAIQuality(els.openaiQuality.value as OpenAIImageQuality);
    });
    els.downloadBtn.addEventListener("click", () => {
      if (!currentImage) return;
      downloadBlob(currentImage.blob, suggestedFilename(currentImage.prompt));
    });
    els.clearGalleryBtn.addEventListener("click", async () => {
      const ok = window.confirm("Delete every image stored in this browser?");
      if (!ok) return;
      await imagesStore.clear();
      destroyViewer();
      await refreshGallery();
    });
    els.gyroBtn.addEventListener("click", () => void enableGyroscope());
    els.keyModal.addEventListener("click", (e) => {
      if (e.target === els.keyModal && !els.keyCancel.classList.contains("hidden")) {
        closeModal();
      }
    });

    void (async () => {
      populateOpenAIOptions();
      currentProvider = await preferencesStore.getProvider();
      els.openaiSize.value = await preferencesStore.getOpenAISize();
      els.openaiQuality.value = await preferencesStore.getOpenAIQuality();
      await alignProviderWithAvailableKeys();
      applyProviderUI();
      await refreshProviderSwitchVisibility();

      await refreshGallery();
      await refreshGithubProfileUI();
      const items = await imagesStore.list();
      if (items.length > 0) {
        await showImage(items[0]!);
      }
      const key = await getActiveKey();
      if (!key) void openModal("onboarding");
    })();
  </script>
</BaseLayout>
