{
  "name": "360world",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Bring-your-own-key web app to generate and explore AI-made 360° equirectangular panoramas. 100% client-side, data stays in your browser.",
  "license": "MIT",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "start": "netlify dev",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint . && prettier --check .",
    "format": "prettier --write . && eslint . --fix",
    "typecheck": "astro check"
  },
  "dependencies": {
    "@photo-sphere-viewer/core": "5.14.1",
    "@photo-sphere-viewer/gyroscope-plugin": "5.14.1",
    "astro": "6.1.8",
    "idb-keyval": "6.2.2",
    "three": "0.184.0"
  },
  "devDependencies": {
    "@astrojs/check": "0.9.8",
    "@eslint/js": "10.0.1",
    "@netlify/functions": "5.2.0",
    "@tailwindcss/vite": "4.1.18",
    "@types/three": "0.184.0",
    "@vitest/coverage-v8": "4.1.5",
    "eslint": "10.2.1",
    "eslint-plugin-astro": "1.7.0",
    "fake-indexeddb": "6.2.5",
    "happy-dom": "20.9.0",
    "prettier": "3.8.3",
    "prettier-plugin-astro": "0.14.1",
    "tailwindcss": "4.1.18",
    "typescript": "5.9.3",
    "typescript-eslint": "8.59.0",
    "vitest": "4.1.5"
  }
}
